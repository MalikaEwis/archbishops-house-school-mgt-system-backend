{
  "name": "archbishops-house-school-mgt-system",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently --names BACK,FRONT --prefix-colors cyan,magenta \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "npm run dev --workspace=backend",
    "dev:frontend": "npm run dev --workspace=frontend",
    "build": "npm run build --workspace=frontend",
    "seed": "npm run seed --workspace=backend",
    "import:schools": "npm run import:schools       --workspace=backend",
    "import:private": "npm run import:private       --workspace=backend",
    "import:retired": "npm run import:retired       --workspace=backend",
    "import:international": "npm run import:international --workspace=backend",
    "import:rectors": "npm run import:rectors       --workspace=backend",
    "import:fathers": "npm run import:fathers       --workspace=backend",
    "import:vested": "npm run import:vested        --workspace=backend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
